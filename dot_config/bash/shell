# History control
shopt -s histappend
HISTCONTROL=ignoreboth
HISTSIZE=32768
HISTFILESIZE="${HISTSIZE}"

# Autocompletion
if [[ ! -v BASH_COMPLETION_VERSINFO ]]; then
  for _bc_path in /opt/homebrew/share/bash-completion/bash_completion \
                  /usr/share/bash-completion/bash_completion \
                  /etc/bash_completion; do
    if [[ -f "$_bc_path" ]]; then
      source "$_bc_path"
      break
    fi
  done
  unset _bc_path
fi

# Ensure command hashing is off for mise
set +h
