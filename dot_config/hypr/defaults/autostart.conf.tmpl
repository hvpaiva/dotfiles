{{- $uwsm := ne (lookPath "uwsm-app") "" -}}
exec-once = {{ if $uwsm }}uwsm-app -- {{ end }}hypridle
exec-once = {{ if $uwsm }}uwsm-app -- {{ end }}mako
exec-once = {{ if $uwsm }}uwsm-app -- {{ end }}waybar
exec-once = {{ if $uwsm }}uwsm-app -- {{ end }}swaybg -i ~/.config/hypr/wallpaper.jpg -m fill
exec-once = {{ if $uwsm }}uwsm-app -- {{ end }}swayosd-server
exec-once = /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1

# Import environment for systemd/dbus (portal support, screen sharing, etc.)
exec-once = systemctl --user import-environment $(env | cut -d'=' -f 1)
exec-once = dbus-update-activation-environment --systemd --all
