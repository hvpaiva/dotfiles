#!/usr/bin/env bash
# launch-browser [--private] — open default browser via xdg
browser=$(xdg-settings get default-web-browser 2>/dev/null | sed 's/\.desktop$//')

if [[ "$1" == "--private" ]]; then
    case "$browser" in
        *firefox*|*zen*|*librewolf*) uwsm-app -- "$browser" --private-window ;;
        *chrom*|*brave*|*edge*)      uwsm-app -- "$browser" --incognito ;;
        *)                           uwsm-app -- xdg-open "https://" ;;
    esac
else
    uwsm-app -- xdg-open "https://"
fi
