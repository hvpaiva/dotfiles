#!/bin/bash
# chezmoi run_onchange_after: Install all packages for this profile.
# Re-runs automatically when package lists or install scripts change.
set -uo pipefail

# Package list hashes (changing any list triggers re-run):
{{ if eq .chezmoi.os "darwin" -}}
# Brewfile hash: {{ include "dot_config/packages/macos/Brewfile" | sha256sum }}
{{ if or (eq .purpose "work") (eq .purpose "both") -}}
# Brewfile.work hash: {{ include "dot_config/packages/macos/Brewfile.work" | sha256sum }}
{{ end -}}
{{ else if eq .distro "arch" -}}
# arch/core hash: {{ include "dot_config/packages/arch/core.txt" | sha256sum }}
# arch/dev hash: {{ include "dot_config/packages/arch/dev.txt" | sha256sum }}
# arch/apps hash: {{ include "dot_config/packages/arch/apps.txt" | sha256sum }}
{{ if eq .profile "desktop" -}}
# arch/desktop hash: {{ include "dot_config/packages/arch/desktop.txt" | sha256sum }}
# arch/gaming hash: {{ include "dot_config/packages/arch/gaming.txt" | sha256sum }}
{{ end -}}
{{ if or (eq .purpose "work") (eq .purpose "both") -}}
# arch/work hash: {{ include "dot_config/packages/arch/work.txt" | sha256sum }}
{{ end -}}
{{ else if or (eq .distro "ubuntu") (eq .distro_family "debian") -}}
# ubuntu/core hash: {{ include "dot_config/packages/ubuntu/core.txt" | sha256sum }}
# ubuntu/dev hash: {{ include "dot_config/packages/ubuntu/dev.txt" | sha256sum }}
# ubuntu/apps hash: {{ include "dot_config/packages/ubuntu/apps.txt" | sha256sum }}
{{ if .has_hyprland -}}
# ubuntu/desktop hash: {{ include "dot_config/packages/ubuntu/desktop.txt" | sha256sum }}
{{ end -}}
{{ if or (eq .purpose "work") (eq .purpose "both") -}}
# ubuntu/work hash: {{ include "dot_config/packages/ubuntu/work.txt" | sha256sum }}
{{ end -}}
# install-extras hash: {{ include "dot_config/packages/ubuntu/executable_install-extras.sh" | sha256sum }}
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
# ─── macOS: Homebrew ─────────────────────────────────────────────────
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv)"

BREWDIR="$HOME/.config/packages/macos"
BREWFILE="$BREWDIR/Brewfile"
[[ -f "$BREWFILE" ]] || { echo "ERROR: $BREWFILE not found"; exit 1; }

LISTS=("$BREWFILE")
{{ if or (eq .purpose "work") (eq .purpose "both") -}}
LISTS+=("$BREWDIR/Brewfile.work")
{{ end -}}

echo ""
echo "======================================"
echo " Package Installation (Homebrew)"
echo " profile={{ .profile }}  purpose={{ .purpose }}"
echo "======================================"
echo "Brewfiles: ${LISTS[*]}"
echo ""

for f in "${LISTS[@]}"; do
  [[ -f "$f" ]] && brew bundle --file="$f" --no-lock
done

{{ else if eq .distro "arch" -}}
# ─── Arch Linux: pacman / yay / paru ────────────────────────────────
PKGDIR="$HOME/.config/packages/arch"
SCRIPT="$HOME/.config/scripts/install_pkgs.sh"

if [[ ! -d "$PKGDIR" ]]; then
  echo "ERROR: Package directory $PKGDIR not found."
  exit 1
fi

if [[ ! -x "$SCRIPT" ]]; then
  echo "ERROR: Install script $SCRIPT not found or not executable."
  exit 1
fi

# Ensure sudo is available and cached
if ! command -v sudo &>/dev/null; then
  echo "ERROR: sudo not found. Cannot install packages."
  exit 1
fi
echo "Caching sudo credentials..."
sudo -v

# Ensure yay is installed (needed for AUR packages)
if ! command -v yay &>/dev/null; then
  echo "Installing yay from AUR..."
  sudo pacman -S --noconfirm --needed git base-devel
  tmpdir=$(mktemp -d)
  git clone https://aur.archlinux.org/yay-bin.git "$tmpdir/yay-bin"
  (cd "$tmpdir/yay-bin" && makepkg -si --noconfirm)
  rm -rf "$tmpdir"
fi

# Build the list of package files for this profile
LISTS=("$PKGDIR/core.txt" "$PKGDIR/dev.txt" "$PKGDIR/apps.txt")

{{ if eq .profile "desktop" -}}
LISTS+=("$PKGDIR/desktop.txt" "$PKGDIR/gaming.txt")
{{ end -}}
{{ if or (eq .purpose "work") (eq .purpose "both") -}}
LISTS+=("$PKGDIR/work.txt")
{{ end -}}

echo ""
echo "======================================"
echo " Package Installation (pacman/yay)"
echo " profile={{ .profile }}  purpose={{ .purpose }}"
echo "======================================"
echo "Lists: ${LISTS[*]}"
echo ""

"$SCRIPT" "${LISTS[@]}"

{{ else if or (eq .distro "ubuntu") (eq .distro_family "debian") -}}
# ─── Ubuntu/Debian: apt ──────────────────────────────────────────────
PKGDIR="$HOME/.config/packages/ubuntu"
SETUP_REPOS="$PKGDIR/ppas-and-repos.sh"
INSTALL_EXTRAS="$PKGDIR/install-extras.sh"
SCRIPT="$PKGDIR/install_pkgs.sh"

if [[ ! -d "$PKGDIR" ]]; then
  echo "ERROR: Package directory $PKGDIR not found."
  exit 1
fi

# Ensure sudo is available and cached
if ! command -v sudo &>/dev/null; then
  echo "ERROR: sudo not found. Cannot install packages."
  exit 1
fi
echo "Caching sudo credentials..."
sudo -v

# 1. Setup external repos (PPAs, Docker, GitHub CLI, etc.)
if [[ -x "$SETUP_REPOS" ]]; then
  echo ""
  echo "======================================"
  echo " Setting up APT repositories"
  echo "======================================"
  echo ""
  "$SETUP_REPOS"
fi

# 2. Install apt packages
LISTS=("$PKGDIR/core.txt" "$PKGDIR/dev.txt" "$PKGDIR/apps.txt")

{{ if .has_hyprland -}}
LISTS+=("$PKGDIR/desktop.txt")
{{ end -}}

{{ if or (eq .purpose "work") (eq .purpose "both") -}}
LISTS+=("$PKGDIR/work.txt")
{{ end -}}

echo ""
echo "======================================"
echo " Package Installation (apt)"
echo " distro={{ .distro }}  purpose={{ .purpose }}"
echo "======================================"
echo "Lists: ${LISTS[*]}"
echo ""

if [[ -x "$SCRIPT" ]]; then
  "$SCRIPT" "${LISTS[@]}"
else
  echo "ERROR: Install script $SCRIPT not found or not executable."
  exit 1
fi

{{ if .has_1password -}}
# 3. Install 1Password CLI
if ! command -v op &>/dev/null; then
  echo ""
  echo "======================================"
  echo " Installing 1Password CLI"
  echo "======================================"
  echo ""
  curl -sS https://downloads.1password.com/linux/keys/1password.asc \
    | sudo gpg --dearmor -o /usr/share/keyrings/1password-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" \
    | sudo tee /etc/apt/sources.list.d/1password.list > /dev/null
  sudo apt-get update
  sudo apt-get install -y 1password-cli
fi
{{ end -}}

# Install extras (binaries, tools not in apt)
if [[ -x "$INSTALL_EXTRAS" ]]; then
  echo ""
  echo "======================================"
  echo " Installing extra tools"
  echo "======================================"
  echo ""
  "$INSTALL_EXTRAS"
fi

{{ else -}}
# ─── Unsupported distro: skip system packages ───────────────────────
echo ""
echo "======================================"
echo " Package Installation"
echo " distro={{ .distro }} (no system package support yet)"
echo "======================================"
echo ""
echo "System package installation is not configured for {{ .distro }}."
echo "Only universal packages (cargo, npm, go, pip) will be installed"
echo "by the finalize script."
echo ""
echo "To add support for {{ .distro }}:"
echo "  1. Create ~/.local/share/chezmoi/dot_config/packages/{{ .distro }}/"
echo "  2. Add package lists (core.txt, dev.txt, etc.)"
echo "  3. Create an installer script or extend install_pkgs.sh"
echo ""
{{ end -}}
